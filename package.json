{
  "name": "image-studio",
  "version": "1.1.0",
  "description": "Local-first image generation studio for OpenAI-compatible image APIs.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "capture:mobile": "npm run build && node scripts/capture-mobile.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cors": "2.8.6",
    "express": "5.2.1",
    "multer": "2.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.15",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "3.4.19"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "image-generation",
    "openai-compatible",
    "react",
    "typescript",
    "vite",
    "express",
    "local-first"
  ]
}
