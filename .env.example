# Local server bind. Keep HOST=127.0.0.1 unless you intentionally want LAN access.
PORT=8787
HOST=127.0.0.1

# Public URL used when Image Studio is exposed through Cloudflare Tunnel / HTTPS.
# Example for Telegram Mini App: https://comfybottg.space
IMAGE_STUDIO_PUBLIC_URL=
# Extra hostnames accepted by Vite dev/preview when you expose the app through a tunnel.
# Comma-separated hostnames, not URLs. Example: comfybottg.space,app.comfybottg.space
IMAGE_STUDIO_ALLOWED_HOSTS=

# Optional provider defaults for the local proxy. UI settings override these values.
OPENAI_API_KEY=
DEFAULT_GENERATION_ENDPOINT=https://api.openai.com/v1/images/generations
DEFAULT_EDIT_ENDPOINT=https://api.openai.com/v1/images/edits
DEFAULT_RESPONSES_ENDPOINT=https://api.openai.com/v1/responses
DEFAULT_MODEL_ID=gpt-image-2

# Encrypted local Storage v2.
IMAGE_STUDIO_DB_PATH=./data/image-studio.sqlite
IMAGE_STUDIO_STORAGE_KEY_FILE=./data/storage.key
# Optional 32-byte base64 key or 64-character hex key. Leave empty to auto-create data/storage.key.
IMAGE_STUDIO_STORAGE_KEY=

# CORS for local development and public tunnel access.
# npm run start now loads .env automatically.
# Local production origins on PORT are allowed automatically; add public HTTPS origins here.
IMAGE_STUDIO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
IMAGE_STUDIO_JSON_LIMIT=256mb

# Optional Cloudflare Tunnel autostart when the production server starts.
# Enable this if the Telegram Mini App should survive PC reboots without a manual cloudflared launch.
IMAGE_STUDIO_TUNNEL_AUTOSTART=false
IMAGE_STUDIO_TUNNEL_COMMAND=cloudflared
# Leave args empty for a quick tunnel: cloudflared tunnel --url http://127.0.0.1:${PORT}
# For a named tunnel/custom domain, use the command you normally run manually, for example:
# IMAGE_STUDIO_TUNNEL_ARGS=tunnel --no-autoupdate --protocol http2 run --token <TOKEN>
# Or explicitly target the local server:
# IMAGE_STUDIO_TUNNEL_ARGS=tunnel --url http://127.0.0.1:${PORT}
# On Windows, --protocol http2 can avoid QUIC/DNS resolver stalls on some networks.
IMAGE_STUDIO_TUNNEL_ARGS=

# Vite dev-server proxy target.
IMAGE_STUDIO_PROXY_TARGET=http://127.0.0.1:8787
